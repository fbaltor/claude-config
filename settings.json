{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "xhigh",
    "CAVEMAN_DEFAULT_MODE": "lite",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(sudo nixos-rebuild *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-fable-5",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/fbaltor/.claude/scripts/node_modules/.bin/tsx \"/home/fbaltor/.claude/scripts/memory/session-start-iwe-memory.ts\"",
            "timeout": 10,
            "statusMessage": "Loading iwe memory map..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/fbaltor/.claude/hooks/user-prompt-memory-nudge.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__iwe-memory__iwe_(create|update|extract|rename|delete|inline|squash)",
        "hooks": [
          {
            "type": "command",
            "command": "/home/fbaltor/.claude/scripts/node_modules/.bin/tsx \"/home/fbaltor/.claude/hooks/post-memory-update-transparency.ts\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/fbaltor/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "caveman@caveman": true,
    "lua-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "sandbox": {
    "enabled": false
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "plansDirectory": "/home/fbaltor/.claude/plans",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "editorMode": "vim",
  "verbose": true,
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true
}
