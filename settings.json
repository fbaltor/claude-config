{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(//home/fbaltor/.claude/**)",
      "Edit(//home/fbaltor/.claude/**)",
      "Read(./**)",
      "Edit(./**)",
      "Read(//tmp/**)",
      "Edit(//tmp/**)",
      "WebSearch",
      "WebFetch",
      "Bash(*)",
      "mcp__linear__list_issues",
      "mcp__linear__get_issue",
      "mcp__linear__save_issue",
      "mcp__linear__get_issue_status",
      "mcp__linear__list_issue_statuses",
      "mcp__linear__list_issue_labels",
      "mcp__linear__create_issue_label",
      "mcp__linear__list_comments",
      "mcp__linear__save_comment",
      "mcp__linear__list_projects",
      "mcp__linear__get_project",
      "mcp__linear__save_project",
      "mcp__linear__list_project_labels",
      "mcp__linear__list_teams",
      "mcp__linear__get_team",
      "mcp__linear__list_users",
      "mcp__linear__get_user",
      "mcp__linear__list_cycles",
      "mcp__linear__list_documents",
      "mcp__linear__get_document",
      "mcp__linear__create_document",
      "mcp__linear__update_document",
      "mcp__linear__list_initiatives",
      "mcp__linear__get_initiative",
      "mcp__linear__save_initiative",
      "mcp__linear__list_milestones",
      "mcp__linear__get_milestone",
      "mcp__linear__save_milestone",
      "mcp__linear__get_status_updates",
      "mcp__linear__save_status_update",
      "mcp__linear__create_attachment",
      "mcp__linear__get_attachment",
      "mcp__linear__extract_images",
      "mcp__linear__search_documentation",
      "mcp__notion__notion-search",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-create-pages",
      "mcp__notion__notion-update-page",
      "mcp__notion__notion-move-pages",
      "mcp__notion__notion-duplicate-page",
      "mcp__notion__notion-create-database",
      "mcp__notion__notion-update-data-source",
      "mcp__notion__notion-create-view",
      "mcp__notion__notion-update-view",
      "mcp__notion__notion-query-database-view",
      "mcp__notion__notion-query-meeting-notes",
      "mcp__notion__notion-create-comment",
      "mcp__notion__notion-get-comments",
      "mcp__notion__notion-get-teams",
      "mcp__notion__notion-get-users"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod -R 777 *)",
      "Bash(chown *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx /home/fbaltor/.claude/hooks/pre-pr-check-doc-sync.ts",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx /home/fbaltor/.claude/hooks/post-pr-update-linear-status.ts",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "npx tsx /home/fbaltor/.claude/hooks/post-checkout-update-linear-status.ts",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/fbaltor/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "plansDirectory": "/home/fbaltor/.claude/plans",
  "autoMemoryEnabled": true
}
