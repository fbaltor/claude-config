{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "MAX_THINKING_TOKENS": "63999"
  },
  "permissions": {
    "allow": [
      "Read(//home/fbaltor/.claude/**)",
      "Edit(//home/fbaltor/.claude/**)",
      "Read(./**)",
      "Edit(./**)",
      "Read(//tmp/**)",
      "Edit(//tmp/**)",
      "Write(//tmp/**)",
      "WebSearch",
      "WebFetch",
      "Bash(*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod -R 777 *)",
      "Bash(chown *)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(* rm -rf *)",
      "Bash(git push *--force*)",
      "Bash(git push *-f *)",
      "Bash(git reset *--hard*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout .)",
      "Bash(git checkout --)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx /home/fbaltor/.claude/hooks/pre-pr-check-doc-sync.ts",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx /home/fbaltor/.claude/hooks/post-pr-update-linear-status.ts",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "npx tsx /home/fbaltor/.claude/hooks/post-checkout-update-linear-status.ts",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/fbaltor/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": false
  },
  "alwaysThinkingEnabled": true,
  "plansDirectory": "/home/fbaltor/.claude/plans",
  "autoMemoryEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "editorMode": "vim",
  "verbose": true,
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true
}
