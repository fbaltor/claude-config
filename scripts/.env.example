# Linear API keys (https://linear.app/settings/api)
# You can use a single key for everything, or separate read/write keys.
# If LINEAR_API_KEY_READ or LINEAR_API_KEY_ALL are not set, LINEAR_API_KEY is used as fallback.
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LINEAR_API_KEY_READ=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LINEAR_API_KEY_ALL=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub token (https://github.com/settings/tokens)
# Optional — falls back to `gh auth token` if not set.
# Needs repo scope for accessing PR reviews.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
