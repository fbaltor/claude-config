# Ignore everything by default
*

# Track config files
!.gitignore
!settings.json

# Track custom commands and agents
!commands/
!commands/**
!agents/
!agents/**

# Track plugin configs (not auto-refreshed metadata)
!plugins/
!plugins/config.json
!plugins/installed_plugins.json

# Track plans and research
!plans/
!plans/**
!research/
!research/**
