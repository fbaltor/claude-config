# Ignore everything by default
*

# Track config files
!.gitignore
!settings.json

# Track agents and skills
!agents/
!agents/**
!skills/
!skills/**

# Track statusline
!statusline.sh

# Track plugin configs (not auto-refreshed metadata)
!plugins/
!plugins/config.json
!plugins/installed_plugins.json

# Track plans and research
!plans/
!plans/**
!research/
!research/**
