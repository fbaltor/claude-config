# Ignore everything by default
*

# Track config files
!.gitignore
!README.md
!CLAUDE.md
!settings.json

# Track scripts
!scripts/
!scripts/**
scripts/.env

node_modules

# Track skills
!skills/
!skills/**

# Track hooks
!hooks/
!hooks/**
hooks/hook-debug.log

# Track statusline
!statusline.sh

# Track plugin configs (not auto-refreshed metadata)
!plugins/
!plugins/config.json
!plugins/installed_plugins.json

# Plans and research are ignored by default
# Use `git add -f` to track specific ones
hooks/*.log
